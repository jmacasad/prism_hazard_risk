ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HuggingFace API (optional — enables smolagents web scraping for property data)
HF_TOKEN=your_huggingface_token_here

# Tavily API (fallback — used if HF_TOKEN not set)
TAVILY_API_KEY=your_tavily_api_key_here

# Domain API (optional — enables real property value estimates)
DOMAIN_CLIENT_ID=your_domain_client_id
DOMAIN_CLIENT_SECRET=your_domain_client_secret
